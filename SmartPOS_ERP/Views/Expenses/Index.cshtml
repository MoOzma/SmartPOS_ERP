@model IEnumerable<SmartPOS_ERP.Models.Expense>

<div class="container-fluid bg-dark text-white p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-info fw-bold">سجل المصروفات الإدارية</h2>
        <a asp-action="Create" class="btn btn-info rounded-pill px-4">
            <i class="fas fa-plus me-1"></i> إضافة مصروف
        </a>
    </div>

    <div class="card bg-dark border-secondary shadow">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle">
                <thead>
                    <tr class="text-muted border-secondary">
                        <th>التاريخ</th>
                        <th>الفئة</th>
                        <th>الوصف</th>
                        <th>المبلغ</th>
                        <th class="text-center">إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ExpenseDate.ToString("yyyy-MM-dd")</td>
                            <td><span class="badge bg-secondary">@item.Category</span></td>
                            <td>@item.Description</td>
                            <td class="text-danger fw-bold">@item.Amount.ToString("N2") LE</td>
                            <td class="text-center">
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('هل أنت متأكد من الحذف؟')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger border-0">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>