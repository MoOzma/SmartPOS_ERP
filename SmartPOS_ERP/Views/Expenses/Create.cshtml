@model SmartPOS_ERP.Models.Expense

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card bg-dark text-white border-secondary shadow-lg">
                <div class="card-header border-secondary bg-secondary bg-opacity-10">
                    <h4 class="mb-0 text-info"><i class="fas fa-money-bill-wave me-2"></i> تسجيل مصروف جديد</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div class="mb-3">
                            <label class="form-label text-info">نوع المصروف (الفئة)</label>
                            <select asp-for="Category" class="form-select bg-dark text-white border-secondary">
                                <option value="إيجار">إيجار</option>
                                <option value="كهرباء/مياه">كهرباء / مياه</option>
                                <option value="أدوات تشغيل (أكياس/ورق)">أدوات تشغيل (أكياس/ورق)</option>
                                <option value="صيانة">صيانة</option>
                                <option value="نثريات">نثريات</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-info">الوصف</label>
                            <input asp-for="Description" class="form-control bg-dark text-white border-secondary" placeholder="مثلاً: فاتورة كهرباء شهر فبراير" required />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-info">المبلغ</label>
                                <input asp-for="Amount" type="number" step="0.01" class="form-control bg-dark text-white border-secondary" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-info">التاريخ</label>
                                <input asp-for="ExpenseDate" type="date" class="form-control bg-dark text-white border-secondary" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-info fw-bold">حفظ المصروف</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>