@model SmartPOS_ERP.Models.Product

@{
    ViewData["Title"] = "تعديل منتج";
}

<div class="container-fluid bg-dark text-white p-4" style="min-height: 90vh; background-color: #1a1d21 !important;">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-lg border-0" style="background-color: #25292e; border-radius: 15px;">
                <div class="card-header border-secondary bg-transparent py-3 d-flex justify-content-between align-items-center">
                    <h4 class="text-info mb-0"><i class="fas fa-edit me-2"></i> تعديل بيانات المنتج: @Model.Name</h4>
                    <span class="badge bg-outline-info border text-info px-3">رقم المنتج #@Model.Id</span>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-white-50">اسم المنتج</label>
                                <input asp-for="Name" class="form-control bg-dark text-white border-secondary rounded-pill px-3" required />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label text-white-50">الباركود</label>
                                <input asp-for="Barcode" class="form-control bg-dark text-white border-secondary rounded-pill px-3" />
                                <span asp-validation-for="Barcode" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label text-white-50">سعر البيع (LE)</label>
                                <input asp-for="SalePrice" type="number" step="0.01" class="form-control bg-dark text-white border-secondary rounded-pill px-3" required />
                                <span asp-validation-for="SalePrice" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label text-white-50">سعر الشراء</label>
                                <input asp-for="CostPrice" type="number" step="0.01" class="form-control bg-dark text-white border-secondary rounded-pill px-3" required />
                                <span asp-validation-for="CostPrice" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label text-white-50">الكمية الحالية</label>
                                <input asp-for="StockQuantity" type="number" step="0.01" class="form-control bg-dark text-white border-secondary rounded-pill px-3" required />
                                <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label text-white-50">حد إعادة الطلب</label>
                                <input asp-for="ReorderLevel" class="form-control bg-dark text-white border-secondary rounded-pill px-3" />
                                <span asp-validation-for="ReorderLevel" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label text-white-50">نوع وحدة البيع</label>
                                <select asp-for="Unit" class="form-select bg-dark text-white border-secondary rounded-pill px-3">
                                    <option value="">-- اختر النوع --</option>
                                    <option value="Piece">بالقطعة (عدد)</option>
                                    <option value="Kilo">بالكيلو (ميزان/جرامات)</option>
                                </select>
                                <span asp-validation-for="Unit" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12 mb-3">
                                <div class="form-check form-switch mt-2">
                                    <input class="form-check-input" type="checkbox" asp-for="TrackInventory" id="trackStock">
                                    <label class="form-check-label text-white-50" for="trackStock">تفعيل تتبع المخزون لهذا المنتج</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4 border-top border-secondary pt-4">
                            <button type="submit" class="btn btn-info rounded-pill px-5 fw-bold text-dark">
                                <i class="fas fa-save me-2"></i> حفظ التعديلات
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                                <i class="fas fa-times me-2"></i> إلغاء
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* تنسيقات متوافقة مع باقي النظام */
    .form-control:focus, .form-select:focus {
        background-color: #1a1d21 !important;
        border-color: #0dcaf0 !important;
        color: white !important;
        box-shadow: 0 0 8px rgba(13, 202, 240, 0.2);
    }

    .form-check-input:checked {
        background-color: #0dcaf0;
        border-color: #0dcaf0;
    }

    label {
        font-size: 0.85rem;
        margin-bottom: 5px;
    }

    .card {
        transition: transform 0.3s ease;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}