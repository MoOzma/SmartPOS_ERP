@model IEnumerable<SmartPOS_ERP.Models.MonthlyProfitViewModel>

@{
    ViewData["Title"] = "تقرير الأرباح والخسائر";
    var currentMonth = DateTime.Now.ToString("yyyy-MM");
    var currentData = Model.FirstOrDefault(m => m.Month == currentMonth);
    decimal monthProfit = currentData?.TotalProfit ?? 0;
    decimal monthSales = currentData?.TotalSales ?? 0;
}

<div class="container-fluid bg-dark text-white p-4" style="min-height: 100vh;">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-3">
        <h2 class="text-info fw-bold mb-0"><i class="fas fa-chart-pie me-2"></i> الأرباح والخسائر</h2>
        <div class="text-muted">تحديث تلقائي بناءً على المبيعات والمصاريف</div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card bg-dark border-info border-opacity-50 shadow-lg h-100">
                <div class="card-body text-center p-4">
                    <i class="fas fa-shopping-cart text-info fs-1 mb-3"></i>
                    <h6 class="text-uppercase small text-white-50">مبيعات الشهر الحالي</h6>
                    <h2 class="fw-bold text-white">@monthSales.ToString("N2") <small class="fs-6">LE</small></h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-dark border-success border-opacity-50 shadow-lg h-100">
                <div class="card-body text-center p-4">
                    <i class="fas fa-hand-holding-usd text-success fs-1 mb-3"></i>
                    <h6 class="text-uppercase small text-white-50">صافي ربح الشهر</h6>
                    <h2 class="fw-bold text-success">@monthProfit.ToString("N2") <small class="fs-6">LE</small></h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-dark border-warning border-opacity-50 shadow-lg h-100">
                <div class="card-body text-center p-4">
                    <i class="fas fa-percentage text-warning fs-1 mb-3"></i>
                    <h6 class="text-uppercase small text-white-50">نسبة الربح</h6>
                    <h2 class="fw-bold text-warning">@(monthSales > 0 ? ((monthProfit / monthSales) * 100).ToString("N1") : "0")%</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="card bg-dark border-secondary shadow">
        <div class="card-header bg-secondary bg-opacity-10 border-secondary d-flex justify-content-between align-items-center">
            <h5 class="mb-0 text-white fw-bold">تحليل الشهور السابقة</h5>
            <button class="btn btn-sm btn-outline-light" onclick="window.print()"><i class="fas fa-print me-1"></i> طباعة التقرير</button>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0 align-middle text-center">
                    <thead class="table-dark border-secondary">
                        <tr class="text-muted small">
                            <th>الشهر / السنة</th>
                            <th>إجمالي المبيعات</th>
                            <th>إجمالي التكلفة والمصاريف</th>
                            <th>صافي الربح الصافي</th>
                            <th>الحالة</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var totalCosts = item.TotalSales - item.TotalProfit;
                            <tr>
                                <td class="fw-bold text-info">@item.Month</td>
                                <td>@item.TotalSales.ToString("N2")</td>
                                <td class="text-muted">@totalCosts.ToString("N2")</td>
                                <td class="fw-bold @(item.TotalProfit >= 0 ? "text-success" : "text-danger")">
                                    @item.TotalProfit.ToString("N2") LE
                                </td>
                                <td>
                                    @if (item.TotalProfit >= 0)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success px-3">رابع</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger px-3">خاسر</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: rgba(255, 255, 255, 0.05) !important;
    }

    .card {
        transition: transform 0.2s;
    }

        .card:hover {
            transform: translateY(-5px);
        }
</style>