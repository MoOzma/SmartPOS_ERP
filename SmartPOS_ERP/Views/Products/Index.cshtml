@model IEnumerable<SmartPOS_ERP.Models.Product>

<div class="container-fluid bg-dark text-white" style="min-height: 100vh; background-color: #1a1d21 !important;">
    <div class="row">
        <div class="col-md-8 p-4">
            <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 p-3 rounded shadow-sm" style="background-color: #25292e;">
                <div class="d-flex align-items-center gap-3">
                    <h3 class="text-info fw-bold mb-0">المنتجات</h3>
                    <div class="vr bg-secondary mx-2" style="height: 30px;"></div>
                    <span class="text-white small">أهلاً، <strong class="text-warning">@Context.Session.GetString("UserName")</strong></span>
                </div>

                <div class="flex-grow-1 mx-lg-4 my-2 my-lg-0" style="max-width: 450px;">
                    <div class="input-group">
                        <span class="input-group-text bg-dark border-secondary text-info"><i class="fas fa-search"></i></span>
                        <input type="text" id="searchInput" class="form-control bg-dark text-white border-secondary rounded-end-pill px-3"
                               placeholder="مرر الباركود أو ابحث بالاسم..." autofocus>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    @if (Context.Session.GetString("UserRole") == "Admin")
                    {
                        <a asp-action="Create" class="btn btn-sm btn-outline-info rounded-pill px-3"> + إضافة جديد </a>
                    }
                </div>
            </div>

            <div class="row" id="productGrid">
                @foreach (var item in Model)
                {
                    string statusBorder = item.StockQuantity <= 0 ? "border-danger" : (item.StockQuantity < 5 ? "border-warning" : "border-secondary");

                    <div class="col-xl-3 col-lg-4 col-md-6 mb-4">
                        <div class="card h-100 product-card shadow-lg bg-dark text-white border-2 @statusBorder" style="border-radius: 12px; overflow: hidden; position: relative;">

                            @if (Context.Session.GetString("UserRole") == "Admin")
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning"
                                   style="position: absolute; top: 10px; right: 10px; z-index: 10; border-radius: 50%; width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; opacity: 0.9;">
                                    <i class="fas fa-edit fa-xs"></i>
                                </a>
                            }

                            <div class="card-body d-flex flex-column text-center p-3" style="cursor: pointer;"
                                 onclick="validateProductSelection('@item.Id', '@item.Name', '@item.SalePrice','@item.Unit')">
                                <h6 class="card-title text-white fw-bold mb-2 mt-2">@item.Name</h6>
                                <h5 class="text-info fw-bold my-2">@item.SalePrice.ToString("N2") LE</h5>
                                <div class="mt-auto">
                                     <span class="badge @(item.StockQuantity <= 0 ? "bg-danger" : "bg-dark border border-secondary") text-white w-100 py-2">
                                        المخزون: @item.StockQuantity @(item.Unit.ToString() == "Kilo" ? "كجم" : "قطعة")
                                    </span> 
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="col-md-4 p-4 shadow-lg" style="min-height: 100vh; background-color: #1a1d21 !important; border-right: 1px solid #3d444d;">
            <h4 class="text-white border-bottom border-secondary pb-3 mb-4 fw-bold">🧾 الفاتورة الحالية</h4>

            <div id="cartContainer" class="pe-2 text-white" style="max-height: 60vh; overflow-y: auto;">
                <p class="text-secondary text-center py-5" id="emptyCartMsg">السلة فارغة</p>
                <div id="cartItemsList"></div>
            </div>

            <div class="mt-4 pt-3 border-top border-secondary text-white">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-secondary">الإجمالي الفرعي:</span>
                    <span id="subtotal" class="fw-bold">0.00</span>
                </div>
                <div class="d-flex justify-content-between text-info mb-2">
                    <span>الضريبة (14%):</span>
                    <span id="tax" class="fw-bold">0.00</span>
                </div>
                <div class="d-flex justify-content-between fs-3 fw-bold text-warning mt-3 pt-3 border-top border-secondary">
                    <span>الإجمالي:</span>
                    <span id="total">0.00</span>
                </div>
                <button class="btn btn-success btn-lg w-100 mt-4 fw-bold rounded-pill py-3 shadow" onclick="checkout()">
                    <i class="fas fa-check-double me-2"></i> دفع وتصديق
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .product-card {
        transition: 0.3s ease;
        border-style: solid !important;
    }

        .product-card:hover {
            transform: translateY(-5px);
            border-color: #0dcaf0 !important;
        }

    #cartContainer::-webkit-scrollbar {
        width: 5px;
    }

    #cartContainer::-webkit-scrollbar-thumb {
        background: #3d444d;
        border-radius: 10px;
    }
</style>


<div id="weightModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.85); z-index:9999; justify-content:center; align-items:center;">
    <div class="bg-dark text-white p-4 rounded-4 border border-info shadow-lg" style="width:450px;">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 id="mProductName" class="text-info fw-bold mb-0">اسم المنتج</h4>
            <button type="button" class="btn-close btn-close-white" onclick="closeWeightModal()"></button>
        </div>

        <p class="text-white small">سعر الكيلو الحالي: <span id="mProductPrice" class="text-warning fw-bold">0.00</span> ج.م</p>

        <div class="row g-3">
            <div class="col-12">
                <label class="form-label text-white">الوزن المطلوب (بالكيلو)</label>
                <div class="input-group">
                    <input type="number" id="mInputWeight" class="form-control bg-black text-info border-secondary fs-3 text-center" step="0.001" placeholder="0.000">
                    <span class="input-group-text bg-secondary text-white">كجم</span>
                </div>
            </div>

            <div class="col-12 text-center my-1">
                <span class="badge bg-secondary opacity-50">أو</span>
            </div>

            <div class="col-12">
                <label class="form-label text-light">القيمة المطلوبة (بالجنيه)</label>
                <div class="input-group">
                    <input type="number" id="mInputMoney" class="form-control bg-black text-warning border-secondary fs-3 text-center" step="0.1" placeholder="0.00">
                    <span class="input-group-text bg-secondary text-white">ج.م</span>
                </div>
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button class="btn btn-info btn-lg flex-grow-1 fw-bold rounded-pill" onclick="confirmWeightAddition()">إضافة للفاتورة</button>
            <button class="btn btn-outline-light btn-lg rounded-pill" onclick="closeWeightModal()">إلغاء</button>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        let currentProduct = null;
        let cart = [];

        // 1. دالة الفحص الرئيسية (التي يتم استدعاؤها عند الضغط على المنتج)
        function validateProductSelection(id, name, price, unit) {
            // التحقق من النص القادم من قاعدة البيانات
            if (unit === "Kilo") {
                openWeightModal(id, name, price);
            } else {
                addToCart(id, name, price, 1, "Piece");
            }
        }

        // 2. دوال النافذة المنبثقة (Modal)
                function openWeightModal(id, name, price) {
            currentProduct = { id, name, price: parseFloat(price), unit: "Kilo" };
            // تعديل الأسماء لتطابق الـ HTML الموجود في ملفك
            document.getElementById('mProductName').innerText = name;
            document.getElementById('mProductPrice').innerText = price;

            document.getElementById('mInputWeight').value = '';
            document.getElementById('mInputMoney').value = '';
            document.getElementById('weightModal').style.display = 'flex';

            setTimeout(() => document.getElementById('mInputWeight').focus(), 100);
        }

        function closeWeightModal() {
            document.getElementById('weightModal').style.display = 'none';
            currentProduct = null;
        }

        // 3. الربط الذكي (الحساب التلقائي داخل النافذة)
                document.getElementById('mInputWeight').addEventListener('input', function() {
            if (currentProduct) {
                let weight = parseFloat(this.value) || 0;
                document.getElementById('mInputMoney').value = (weight * currentProduct.price).toFixed(2);
            }
        });

        document.getElementById('mInputMoney').addEventListener('input', function() {
            if (currentProduct) {
                let money = parseFloat(this.value) || 0;
                document.getElementById('mInputWeight').value = (money / currentProduct.price).toFixed(3);
            }
        });

                function confirmWeightAddition() {
            // التأكد من استخدام المعرف الصحيح الموجود في الـ HTML الخاص بك
            let qtyInput = document.getElementById('mInputWeight');
            let qty = parseFloat(qtyInput.value);

            if (qty > 0 && currentProduct) {
                // إضافة المنتج بالوزن المكتوب
                addToCart(currentProduct.id, currentProduct.name, currentProduct.price, qty, "Kilo");
                closeWeightModal();

                // تصفير الحقل للعملية القادمة
                qtyInput.value = '';
            } else {
                alert("يرجى إدخال وزن صحيح أولاً");
            }
        }

        // 4. دالة الإضافة الفعلية للسلة
        function addToCart(id, name, price, qty, unit) {
            let productId = id.toString();
            let existing = cart.find(i => i.id === productId);

            if (existing && unit === "Piece") {
                existing.qty += 1;
            } else {
                // إضافة سجل جديد (يسمح بتعدد سجلات الكيلو لبيانات مختلفة لنفس المنتج)
                cart.push({
                    id: productId,
                    name: name,
                    price: parseFloat(price),
                    qty: parseFloat(qty),
                    unit: unit
                });
            }
            renderCart();
        }

        // 5. دالة عرض السلة وتحديث الحسابات
        function renderCart() {
            const listContainer = document.getElementById('cartItemsList');
            const emptyMsg = document.getElementById('emptyCartMsg');
            if (!listContainer) return;

            listContainer.innerHTML = '';
            let subtotal = 0;

            if (cart.length === 0) {
                if (emptyMsg) emptyMsg.style.display = 'block';
            } else {
                if (emptyMsg) emptyMsg.style.display = 'none';
                cart.forEach((item, index) => {
                    let itemTotal = item.price * item.qty;
                    subtotal += itemTotal;

                    let unitLabel = (item.unit === "Kilo") ? "كجم" : "قطعة";
                    let qtyDisplay = (item.unit === "Kilo") ? item.qty.toFixed(3) : item.qty;

                    const itemRow = document.createElement('div');
                    itemRow.className = "d-flex justify-content-between align-items-center mb-2 bg-dark p-2 rounded border border-secondary text-white";
                    itemRow.innerHTML = `
                        <div style="flex-grow: 1;">
                            <div class="fw-bold">${item.name}</div>
                            <small class="text-info">${qtyDisplay} ${unitLabel} × ${item.price.toFixed(2)}</small>
                        </div>
                        <div class="text-warning mx-2 fw-bold">${itemTotal.toFixed(2)}</div>
                        <button class="btn btn-sm btn-outline-danger border-0" onclick="removeFromCart(${index})">
                            <i class="fas fa-trash"></i>
                        </button>
                    `;
                    listContainer.appendChild(itemRow);
                });
            }

            // تحديث الإجماليات (الضريبة 14% حسب الموديل)
            let tax = subtotal * 0.14;
            let total = subtotal + tax;
            document.getElementById('subtotal').innerText = subtotal.toFixed(2);
            document.getElementById('tax').innerText = tax.toFixed(2);
            document.getElementById('total').innerText = total.toFixed(2);
        }

        function removeFromCart(index) {
            cart.splice(index, 1);
            renderCart();
        }

        // 6. إنهاء العملية وإرسال البيانات للسيرفر
        function checkout() {
            if (cart.length === 0) return;

            let orderData = {
                totalAmount: parseFloat(document.getElementById('total').innerText),
                taxAmount: parseFloat(document.getElementById('tax').innerText),
                orderDetails: cart.map(item => ({
                    productId: parseInt(item.id),
                    quantity: item.qty,
                    unitPrice: item.price
                }))
            };

            fetch('/Products/SaveOrder', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(orderData)
            }).then(response => {
                if (response.ok) {
                    alert("تم حفظ الفاتورة بنجاح!");
                    cart = [];
                    renderCart();
                    location.reload();
                } else {
                    alert("فشلت عملية الحفظ، تأكد من الاتصال بالسيرفر");
                }
            });
        }

        // 7. مستمع الباركود (بدون إخفاء المنتجات)
        document.getElementById('searchInput').addEventListener('input', function (e) {
            let val = e.target.value.trim();
            if (val === "") return;

            @foreach (var item in Model)
            {
                    <text>
                    if (val === "@item.Barcode") {
                        validateProductSelection('@item.Id', '@item.Name', '@item.SalePrice', '@item.Unit');
                        e.target.value = '';
                    }
                    </text>
            }
        });
    </script>
}