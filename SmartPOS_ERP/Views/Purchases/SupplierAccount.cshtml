@model SmartPOS_ERP.Models.Supplier

@{
    ViewData["Title"] = "كشف حساب مورد";
    // حساب الإجماليات برمجياً باستخدام C#
    decimal totalPurchases = Model.Invoices?.Sum(i => i.Details.Sum(d => d.PackageQuantity * d.PackageCost)) ?? 0;
    decimal totalPaid = Model.Payments?.Sum(p => p.AmountPaid) ?? 0;
    decimal balance = totalPurchases - totalPaid;
}

<div class="container-fluid bg-dark text-white p-4" style="min-height: 100vh;">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-3">
        <div>
            <h2 class="text-info fw-bold mb-0"><i class="fas fa-user-tie me-2"></i> كشف حساب: @Model.Name</h2>
            <p class="text-muted mb-0">رقم الهاتف: @Model.Phone</p>
        </div>
        <div>
            <button type="button" class="btn btn-success rounded-pill px-4 shadow" data-bs-toggle="modal" data-bs-target="#paymentModal">
                <i class="fas fa-hand-holding-usd me-1"></i> تسجيل دفع مبلغ
            </button>
            <button onclick="window.print()" class="btn btn-outline-light rounded-pill ms-2">
                <i class="fas fa-print"></i>
            </button>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card bg-secondary bg-opacity-10 border-info border-opacity-25 h-100 shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-info text-uppercase small fw-bold">إجمالي المسحوبات (المشتريات)</h6>
                    <h2 class="display-6 text-white mt-2">@totalPurchases.ToString("N2") <small class="fs-6">LE</small></h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-secondary bg-opacity-10 border-success border-opacity-25 h-100 shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-success text-uppercase small fw-bold">إجمالي المدفوعات</h6>
                    <h2 class="display-6 fw-bold mt-2 text-success">@totalPaid.ToString("N2") <small class="fs-6">LE</small></h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-secondary bg-opacity-10 border-danger border-opacity-25 h-100 shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-danger text-uppercase small fw-bold">الرصيد المتبقي (المديونية)</h6>
                    <h2 class="display-6 fw-bold mt-2 text-danger">@balance.ToString("N2") <small class="fs-6">LE</small></h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card bg-dark border-secondary shadow">
                <div class="card-header bg-secondary bg-opacity-10 border-secondary">
                    <h5 class="mb-0 text-info"><i class="fas fa-file-invoice me-2"></i> سجل فواتير التوريد</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-dark table-hover mb-0 align-middle text-center">
                        <thead class="table-dark">
                            <tr class="text-muted small">
                                <th>رقم الفاتورة</th>
                                <th>التاريخ</th>
                                <th>القيمة</th>
                                <th>تفاصيل</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var inv in Model.Invoices.OrderByDescending(x => x.PurchaseDate))
                            {
                                <tr>
                                    <td>#@inv.Id</td>
                                    <td>@inv.PurchaseDate.ToString("yyyy-MM-dd")</td>
                                    <td class="fw-bold">@inv.Details.Sum(d => d.PackageQuantity * d.PackageCost).ToString("N2")</td>
                                    <td><a asp-action="Details" asp-route-id="@inv.Id" class="btn btn-sm btn-outline-info rounded-pill"><i class="fas fa-eye"></i></a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card bg-dark border-secondary shadow">
                <div class="card-header bg-secondary bg-opacity-10 border-secondary">
                    <h5 class="mb-0 text-success"><i class="fas fa-receipt me-2"></i> سجل السداد النقدي</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-dark table-striped mb-0 align-middle text-center">
                        <thead>
                            <tr class="text-muted small">
                                <th>التاريخ</th>
                                <th>المبلغ</th>
                                <th>ملاحظات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pay in Model.Payments.OrderByDescending(x => x.PaymentDate))
                            {
                                <tr>
                                    <td class="small">@pay.PaymentDate.ToString("yyyy-MM-dd")</td>
                                    <td class="text-success fw-bold">@pay.AmountPaid.ToString("N2")</td>
                                    <td class="small text-white">@pay.Notes</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="paymentModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary shadow-lg">
            <form asp-action="PaySupplier" method="post">
                <input type="hidden" name="supplierId" value="@Model.Id" />
                <div class="modal-header border-secondary">
                    <h5 class="modal-title text-success">تسجيل دفعة للمورد</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label text-white-50">المبلغ المدفوع</label>
                        <input type="number" step="0.01" name="amount" class="form-control bg-dark text-white border-secondary fs-4 text-center text-success fw-bold" required autofocus>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-white-50">تاريخ الدفعة</label>
                        <input type="date" name="paymentDate" class="form-control bg-dark text-white border-secondary"
                               value="@DateTime.Now.ToString("yyyy-MM-dd")" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-white-50">ملاحظات (طريقة الدفع)</label>
                        <textarea name="notes" class="form-control bg-dark text-white border-secondary" rows="2" placeholder="نقداً، تحويل بنكي، شيك..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="submit" class="btn btn-success w-100 fw-bold py-2 rounded-pill">تأكيد عملية الدفع</button>
                </div>
            </form>
        </div>
    </div>
</div>