@model SmartPOS_ERP.Models.PurchaseViewModel

<div class="container-fluid bg-dark text-white p-4" style="min-height: 100vh;">
    <div class="row g-3 mb-4 p-3 rounded shadow-sm" style="background-color: #25292e;">
        <div class="col-md-6">
            <h3 class="text-info fw-bold mb-0"><i class="fas fa-truck-loading me-2"></i> توريد بضاعة للمخزن</h3>

        </div>

        <div class="col-md-3">
            <select id="supplierId" class="form-select bg-dark text-white border-secondary rounded-pill">
                <option value="">-- اختر المورد --</option>
                @foreach (var s in (IEnumerable<dynamic>)ViewBag.Suppliers)
                {
                    <option value="@s.Id">@s.Name</option>
                }
            </select>
        </div>
        <div class="col-md-3 text-end">
            <input type="date" id="purchaseDate" class="form-control bg-dark text-white border-secondary rounded-pill" value="@DateTime.Now.ToString("yyyy-MM-dd")">
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-5">
            <div class="card bg-secondary bg-opacity-10 border-info border-opacity-25 shadow h-100">
                <div class="card-body">
                    <div class="mb-4">
                        <label class="form-label text-warning fw-bold">1. ابحث عن المنتج</label>
                        <input list="productsData" id="productSearchInput" class="form-control bg-dark text-white border-info rounded-pill p-3" placeholder="اكتب اسم الصنف هنا..." onchange="onProductSelected()">
                        <datalist id="productsData">
                            @foreach (var p in (IEnumerable<dynamic>)ViewBag.Products)
                            {
                                <option value="@p.Name" data-id="@p.Id" data-unit="@p.Unit" data-cost="@p.CostPrice" data-sale="@p.SalePrice">@p.Barcode</option>
                            }
                        </datalist>
                    </div>
                    <div class="d-flex gap-2 mb-3">
                        <a asp-controller="Products" asp-action="Create" target="_blank" class="btn btn-outline-warning btn-sm rounded-pill">
                            <i class="fas fa-plus-circle me-1"></i> إضافة منتج جديد 
                        </a>

                        <button type="button" class="btn btn-outline-success rounded-pill px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#newSupplierModal">
                            <i class="fas fa-user-plus me-1"></i> إضافة مورد جديد
                        </button>
                    </div>
                    <div id="inputFormArea" style="display:none;">
                        <h6 class="text-info border-bottom border-secondary pb-2 mb-3">2. بيانات التوريد لمُنتج <span id="selectedUnitType" class="badge bg-primary"></span></h6>

                        <div id="kiloFields" class="unit-group" style="display:none;">
                            <div class="row g-2">
                                <div class="col-md-6 mb-2">
                                    <label class="small text-secondary">الوزن الوارد (كجم)</label>
                                    <input type="number" id="kiloQty" class="form-control bg-dark text-white border-secondary rounded-pill" placeholder="0.000">
                                </div>
                                <div class="col-md-6 mb-2">
                                    <label class="small text-secondary">سعر شراء الكيلو</label>
                                    <input type="number" id="kiloCost" class="form-control bg-dark text-white border-secondary rounded-pill" placeholder="0.00">
                                </div>
                                <div class="col-12">
                                    <div class="p-2 rounded mb-2" style="background-color: #1e2125; border: 1px dashed #444;">
                                        <small class="text-white d-block">إجمالي حساب المورد عن هذا الصنف:</small>
                                        <span id="kiloTotalLabel" class="text-success fw-bold fs-5">0.00</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div id="pieceFields" class="unit-group" style="display:none;">
                            <div class="row g-2">
                                <div class="col-md-6 mb-2 text-center">
                                    <label class="small text-secondary">عدد العلب</label>
                                    <input type="number" id="pkgQty" class="form-control bg-dark text-white border-secondary rounded-pill" placeholder="0">
                                </div>
                                <div class="col-md-6 mb-2 text-center">
                                    <label class="small text-secondary">قطع/علبة</label>
                                    <input type="number" id="unitsPer" class="form-control bg-dark text-white border-secondary rounded-pill" value="1">
                                </div>
                                <div class="col-md-6 mb-2">
                                    <label class="small text-secondary">سعر العلبة</label>
                                    <input type="number" id="pkgCost" class="form-control bg-dark text-white border-secondary rounded-pill" placeholder="0.00">
                                </div>
                                <div class="col-md-6 mb-2 text-center">
                                    <label class="small text-secondary">سعر القطعة (شراء)</label>
                                    <input type="number" id="singleUnitCost" class="form-control bg-dark text-white border-secondary rounded-pill" readonly tabindex="-1">
                                </div>
                            </div>
                        </div>

                        <div class="mt-3">
                            <label class="small text-warning">سعر البيع الحالي (للعميل)</label>
                            <input type="number" id="newSalePrice" class="form-control bg-dark text-warning border-warning border-opacity-25 rounded-pill fw-bold">
                        </div>

                        <button class="btn btn-info w-100 rounded-pill fw-bold py-2 mt-4 shadow" onclick="addItem()">
                            <i class="fas fa-plus-circle me-1"></i> إضافة الصنف للجدول
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="table-responsive rounded shadow-sm overflow-hidden border border-secondary">
                <table class="table table-dark table-hover mb-0 align-middle">
                    <thead class="table-info text-dark">
                        <tr>
                            <th>الصنف</th>
                            <th>الكمية الواردة</th>
                            <th>التكلفة (إجمالي)</th>
                            <th class="text-center">حذف</th>
                        </tr>
                    </thead>
                    <tbody id="purchaseTableBody"></tbody>
                </table>
            </div>
            <div class="d-flex justify-content-between align-items-center mt-4 p-3 bg-secondary bg-opacity-10 rounded">
                <div class="text-white-50 fs-5">إجمالي المبلغ المستحق للمورد:</div>
                <div class="text-success fw-bold fs-2"><span id="grandTotal">0.00</span> <small class="fs-6">LE</small></div>
            </div>
            <button class="btn btn-success btn-lg w-100 rounded-pill shadow-lg mt-3 fw-bold" onclick="saveAll()">
                <i class="fas fa-save me-2"></i> حفظ الفاتورة وتحديث المخزون
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let items = [];
        let selectedProductData = null;

        function onProductSelected() {
            const input = document.getElementById('productSearchInput');
            const option = document.querySelector(`#productsData option[value='${input.value}']`);

            if (option) {
                selectedProductData = {
                    id: option.getAttribute('data-id'),
                    unit: option.getAttribute('data-unit'),
                    cost: parseFloat(option.getAttribute('data-cost')),
                    sale: parseFloat(option.getAttribute('data-sale'))
                };

                document.getElementById('inputFormArea').style.display = 'block';
                document.getElementById('selectedUnitType').innerText = selectedProductData.unit === "Kilo" ? "وزن" : "علب/قطع";
                document.getElementById('newSalePrice').value = selectedProductData.sale;

                // إظهار الحقول المناسبة
                document.getElementById('kiloFields').style.display = selectedProductData.unit === "Kilo" ? "block" : "none";
                document.getElementById('pieceFields').style.display = selectedProductData.unit === "Piece" ? "block" : "none";
            }
        }

        // حسابات العلب التلقائية
        document.getElementById('pkgCost').addEventListener('input', updatePieceCalculations);
        document.getElementById('unitsPer').addEventListener('input', updatePieceCalculations);

        function updatePieceCalculations() {
            const cost = parseFloat(document.getElementById('pkgCost').value) || 0;
            const per = parseFloat(document.getElementById('unitsPer').value) || 1;
            document.getElementById('singleUnitCost').value = (cost / per).toFixed(2);
        }

        function addItem() {
            if (!selectedProductData) return;

            let item = {
                productId: parseInt(selectedProductData.id),
                name: document.getElementById('productSearchInput').value,
                newSalePrice: parseFloat(document.getElementById('newSalePrice').value)
            };

            if (selectedProductData.unit === "Kilo") {
                const qty = parseFloat(document.getElementById('kiloQty').value) || 0;
                const cost = parseFloat(document.getElementById('kiloCost').value) || 0;
                if (qty <= 0) { alert("أدخل الوزن"); return; }

                item.packageQuantity = qty;
                item.unitsPerPackage = 1; // الكيلو يعامل كوحدة واحدة
                item.packageCost = cost;
                item.totalUnits = qty;
                item.lineTotal = qty * cost;
            } else {
                const pkgQty = parseFloat(document.getElementById('pkgQty').value) || 0;
                const unitsPer = parseFloat(document.getElementById('unitsPer').value) || 1;
                const pkgCost = parseFloat(document.getElementById('pkgCost').value) || 0;
                if (pkgQty <= 0) { alert("أدخل عدد العلب"); return; }

                item.packageQuantity = pkgQty;
                item.unitsPerPackage = unitsPer;
                item.packageCost = pkgCost;
                item.totalUnits = pkgQty * unitsPer;
                item.lineTotal = pkgQty * pkgCost;
            }

            items.push(item);
            renderTable();
            resetInputs();
        }

        function renderTable() {
            const body = document.getElementById('purchaseTableBody');
            let total = 0;
            body.innerHTML = items.map((item, index) => {
                total += item.lineTotal;
                return `
                <tr>
                    <td class="ps-3">${item.name} <small class="text-info d-block">سعر البيع الجديد: ${item.newSalePrice}</small></td>
                    <td>${item.packageQuantity} ${item.unitsPerPackage > 1 ? '(علبة)' : '(كجم)'}</td>
                    <td class="text-success fw-bold">${item.lineTotal.toFixed(2)}</td>
                    <td class="text-center"><button class="btn btn-sm btn-outline-danger border-0" onclick="removeItem(${index})"><i class="fas fa-times"></i></button></td>
                </tr>`;
            }).join('');
            document.getElementById('grandTotal').innerText = total.toFixed(2);
        }

        function resetInputs() {
            document.getElementById('productSearchInput').value = '';
            document.getElementById('inputFormArea').style.display = 'none';
            document.getElementById('kiloQty').value = '';
            document.getElementById('pkgQty').value = '';
        }

                async function quickSaveSupplier() {
            const nameInput = document.getElementById('modalSupName');
            const phoneInput = document.getElementById('modalSupPhone');

            if (!nameInput.value) { alert("يرجى إدخال اسم المورد"); return; }

            try {
                const response = await fetch('/Purchases/CreateQuickSupplier', { // الطلب يذهب لـ PurchasesController
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ Name: nameInput.value, Phone: phoneInput.value })
                });

                if (response.ok) {
                    const result = await response.json();
                    const select = document.getElementById('supplierId');

                    // إضافة المورد الجديد للقائمة وتحديده
                    const newOption = new Option(result.name, result.id, true, true);
                    select.add(newOption);

                    // إغلاق النافذة وتنظيف الحقول
                    bootstrap.Modal.getInstance(document.getElementById('newSupplierModal')).hide();
                    nameInput.value = '';
                    phoneInput.value = '';
                } else {
                    alert("حدث خطأ أثناء حفظ المورد في السيرفر");
                }
            } catch (e) {
                alert("تأكد من إعداد الدالة في PurchasesController");
            }
        }

        async function saveAll() {
            const supplierId = document.getElementById('supplierId').value;
            if (!supplierId || items.length === 0) { alert("أكمل البيانات"); return; }

            const payload = {
                SupplierId: parseInt(supplierId),
                PurchaseDate: document.getElementById('purchaseDate').value,
                Items: items
            };

            const response = await fetch('/Purchases/SavePurchase', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            if (response.ok) {
                alert("✅ تم الحفظ بنجاح وتحديث المخزون وأسعار البيع");
                location.reload();
            } else {
                alert("❌ فشل الحفظ");
            }
        }

        function removeItem(index) { items.splice(index, 1); renderTable(); }


                // استهداف الحقول
        const kiloQtyInput = document.getElementById('kiloQty');
        const kiloCostInput = document.getElementById('kiloCost');
        const kiloTotalLabel = document.getElementById('kiloTotalLabel');

        // دالة الحساب
        function calculateKiloTotal() {
            const qty = parseFloat(kiloQtyInput.value) || 0;
            const cost = parseFloat(kiloCostInput.value) || 0;
            const total = qty * cost;

            // تحديث الرقم الظاهر في الصفحة فوراً
            kiloTotalLabel.innerText = total.toFixed(2);
        }

        // تشغيل الدالة بمجرد الكتابة في أي من الحقلين
        kiloQtyInput.addEventListener('input', calculateKiloTotal);
        kiloCostInput.addEventListener('input', calculateKiloTotal);




    </script>
}
<div class="modal fade" id="newSupplierModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content bg-dark border-secondary">
            <div class="modal-header border-secondary text-info">
                <h5 class="modal-title">تسجيل مورد جديد</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">اسم المورد/الشركة</label>
                    <input type="text" id="modalSupName" class="form-control bg-dark text-white border-secondary">
                </div>
                <div class="mb-3">
                    <label class="form-label">رقم الهاتف</label>
                    <input type="text" id="modalSupPhone" class="form-control bg-dark text-white border-secondary">
                </div>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-success w-100" onclick="quickSaveSupplier()">حفظ المورد</button>
            </div>
        </div>
    </div>
</div>

