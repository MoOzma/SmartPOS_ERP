@model IEnumerable<SmartPOS_ERP.Models.PurchaseInvoice>

<div class="container-fluid bg-dark text-white p-4" style="min-height: 90vh;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-info fw-bold"><i class="fas fa-history me-2"></i> سجل فواتير المشتريات</h3>
        <a asp-action="Create" class="btn btn-success rounded-pill px-4 shadow">
            <i class="fas fa-plus me-1"></i> إضافة فاتورة توريد
        </a>
        
      

    </div>

    <div class="card shadow-sm border-0" style="background-color: #25292e;">
        <div class="card-body p-0">
            <table class="table table-dark table-hover mb-0 align-middle">
                <thead style="background-color: #2c3238;">
                    <tr class="text-info">
                        <th class="ps-4">رقم الفاتورة</th>
                        <th>المورد</th>
                        <th>التاريخ</th>
                        <th>عدد الأصناف</th>
                        <th>إجمالي القيمة</th>
                        <th class="text-center">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-secondary">#@item.Id</td>
                            <td>@item.Supplier?.Name</td>
                            <td>@item.InvoiceDate.ToString("yyyy-MM-dd")</td>
                            <td><span class="badge bg-secondary rounded-pill">@item.Details.Count</span></td>
                            <td class="text-success fw-bold">
                                @item.Details.Sum(d => d.PackageQuantity * d.PackageCost).ToString("N2") LE
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info rounded-pill px-3">
                                    <i class="fas fa-eye me-1"></i> عرض التفاصيل
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>