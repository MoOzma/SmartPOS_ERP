@{
    Layout = null; // لا نريد القائمة العلوية أو الجانبية في صفحة الدخول
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تسجيل الدخول - Sama_POS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #1a1d21; /* نفس اللون الداكن لمشروعك */
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
        }

        .login-card {
            background-color: #2d3238;
            border: none;
            border-radius: 15px;
            width: 100%;
            max-width: 400px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }
    </style>
</head>
<body>

    <div class="login-card text-white">
        <div class="text-center mb-4">
            <h2 class="text-info">
               Sama_POS
            </h2>
            <p class="text-wite">نظام إدارة المبيعات </p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2">@ViewBag.Error</div>
        }

        <form asp-action="Login" method="post">
            <div class="mb-3">
                <label class="form-label">اسم المستخدم</label>
                <input type="text" name="username" class="form-control bg-dark text-white border-secondary" required />
            </div>
            <div class="mb-3">
                <label class="form-label">كلمة المرور</label>
                <input type="password" name="password" class="form-control bg-dark text-white border-secondary" required />
            </div>
            <button type="submit" class="btn btn-info w-100 fw-bold mt-2">دخول للنظام</button>
        </form>
    </div>

</body>
</html>