@model SmartPOS_ERP.Models.User

<div class="container mt-5 d-flex justify-content-center">
    <div class="card bg-dark text-white shadow-lg border-secondary" style="width: 400px; border-radius: 15px;">
        <div class="card-header text-center border-0 py-4">
            <div class="rounded-circle bg-info d-inline-block p-3 mb-2">
                <i class="fas fa-user-edit fa-2x"></i>
            </div>
            <h4>ملفي الشخصي</h4>
        </div>
        <div class="card-body p-4">
            @if (ViewBag.Message != null)
            {
                <div class="alert alert-success">@ViewBag.Message</div>
            }
            <div class="mb-3">
                <label class="text-muted small">اسم المستخدم</label>
                <input type="text" class="form-control bg-secondary text-white border-0" value="@Model.Username" readonly />
            </div>
            <div class="mb-3">
                <label class="text-muted small">الصلاحية</label>
                <input type="text" class="form-control bg-secondary text-white border-0" value="@Model.Role" readonly />
            </div>

            <form asp-action="Profile" method="post" class="mt-4 border-top pt-3">
                <label class="form-label text-info">تغيير كلمة المرور</label>
                <input type="password" name="newPassword" class="form-control bg-dark text-white border-info mb-3" placeholder="كلمة السر الجديدة" required />
                <button type="submit" class="btn btn-info w-100 fw-bold">تحديث البيانات</button>
            </form>
        </div>
        <div class="card-footer text-center border-0 bg-transparent mb-3">
            <a asp-controller="Products" asp-action="Index" class="text-decoration-none text-muted">العودة للرئيسية</a>
        </div>
    </div>
</div>