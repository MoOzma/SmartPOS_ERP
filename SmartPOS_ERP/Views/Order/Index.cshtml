<div class="container-fluid bg-dark text-white p-4" style="min-height: 100vh;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-info fw-bold"><i class="fas fa-history me-2"></i> سجل الفواتير والمبيعات</h3>
        <span class="badge bg-info p-2">إجمالي العمليات: @Model.Count</span>
    </div>

    <div class="card shadow bg-secondary bg-opacity-10 border-secondary">
        <div class="card-body p-0">
            <table class="table table-dark table-hover mb-0 text-center align-middle">
                <thead class="table-dark border-secondary">
                    <tr>
                        <th>رقم الفاتورة</th>
                        <th>تاريخ ووقت العملية</th>
                        <th>عدد الأصناف</th>
                        <th>الضريبة (14%)</th>
                        <th>الإجمالي النهائي</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td class="fw-bold text-info">#@order.Id</td>
                            <td>
                                <div class="small">@order.OrderDate.ToString("yyyy/MM/dd")</div>
                                <div class="badge bg-dark text-secondary">@order.OrderDate.ToString("hh:mm tt")</div>
                            </td>
                            <td><span class="badge rounded-pill bg-outline-light border px-3">@order.OrderDetails.Count</span></td>
                            <td class="text-muted">@order.TaxAmount.ToString("N2")</td>
                            <td class="fw-bold text-warning fs-5">@order.TotalAmount.ToString("N2") ج.م</td>
                            <td>
                                <a asp-action="OrderDetails"
                                   asp-controller="Order"
                                   asp-route-id="@order.Id"
                                   class="btn btn-info">عرض</a>
                                <button class="btn btn-sm btn-outline-light rounded-pill ms-1">
                                    <i class="fas fa-print"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>