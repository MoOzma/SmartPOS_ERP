@model SmartPOS_ERP.Models.Order

<div class="container mt-5">
    <div class="card bg-dark text-white border-secondary shadow-lg">
        <div class="card-header border-secondary d-flex justify-content-between align-items-center p-4">
            <div>
                <h2 class="text-info fw-bold mb-0">فاتورة بيع #@Model.Id</h2>
                <p class="text-muted mb-0">تاريخ العملية: @Model.OrderDate.ToString("yyyy/MM/dd HH:mm tt")</p>
            </div>
            <div class="text-end">
                <button onclick="window.print()" class="btn btn-outline-light rounded-pill">
                    <i class="fas fa-print me-2"></i> طباعة الفاتورة
                </button>
            </div>
        </div>

        <div class="card-body p-4">
            <table class="table table-dark table-striped border-secondary mt-3">
                <thead class="text-info">
                    <tr>
                        <th>المنتج</th>
                        <th class="text-center">الكمية / الوزن</th>
                        <th class="text-center">سعر الوحدة</th>
                        <th class="text-end">الإجمالي</th>
                        <th class="text-end">الوقت </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var detail in Model.OrderDetails)
                    {
                        <tr>
                            <td>@detail.Product?.Name</td>
                            <td class="text-center">
                                @detail.Quantity.ToString(detail.Product?.Unit == "Kilo" ? "N3" : "N0")
                                @(detail.Product?.Unit == "Kilo" ? " كجم" : " قطعة")
                            </td>
                            <td class="text-center">@detail.UnitPrice.ToString("N2")</td>
                            <td class="text-end fw-bold text-warning">@((detail.Quantity * detail.UnitPrice).ToString("N2"))</td>
                            <td class="text-end fw-bold text-warning">
                                <div class="small">@detail.Order.OrderDate.ToString("yyyy/MM/dd")</div>
                                <div class="badge bg-dark text-white">@detail.Order.OrderDate.ToString("hh:mm tt")</div>
                            </td>
                            <td class="text-end fw-bold text-warning">
                                <button class="btn btn-sm btn-outline-danger"
                                        onclick="returnProduct(@detail.Order.Id, @item.ProductId, @item.Quantity)">
                                    <i class="fa fa-undo"></i> مرتجع
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="row mt-5 justify-content-end">
                <div class="col-md-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span>الإجمالي الفرعي:</span>
                        <span>@((Model.TotalAmount - Model.TaxAmount).ToString("N2")) ج.م</span>
                    </div>
                    
                    <div class="d-flex justify-content-between fs-4 fw-bold text-warning border-top border-secondary pt-2">
                        <span>الإجمالي النهائي:</span>
                        <span>@Model.TotalAmount.ToString("N2") ج.م</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-footer border-secondary text-center p-3 text-muted">
            <p class="mb-0 small">شكراً لتعاملكم معنا - Smart POS System</p>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-link text-info p-0 text-decoration-none">
            <i class="fas fa-arrow-right me-2"></i> العودة لسجل الفواتير
        </a>
    </div>
</div>

<style>
    @@media print {
        body * {
            visibility: hidden;
        }

        .card, .card * {
            visibility: visible;
        }

        .card {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
            border: none !important;
        }

        .btn, .btn-link {
            display: none !important;
        }

        .bg-dark {
            background-color: white !important;
            color: black !important;
        }

        .text-white, .text-info, .text-warning {
            color: black !important;
        }

        .table-dark {
            --bs-table-bg: transparent;
            color: black;
            border-color: #dee2e6;
        }
    }
</style>