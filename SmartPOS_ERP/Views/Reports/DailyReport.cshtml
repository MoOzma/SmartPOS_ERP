<div class="container-fluid bg-dark text-white p-4">
    <h3 class="text-info fw-bold mb-4"><i class="fas fa-file-invoice-dollar me-2"></i> تقرير المبيعات السنوي (آخر 12 شهر)</h3>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-info bg-opacity-10 border-info text-center p-3 shadow-sm">
                <h6 class="text-white">مبيعات اليوم</h6>
                <h2 class="fw-bold">@ViewBag.DailyTotal.ToString("N2") ج.م</h2>
            </div>
        </div>
    </div>

    <div class="card bg-secondary bg-opacity-10 border-secondary shadow">
        <div class="card-header border-secondary bg-transparent">
            <h5 class="mb-0 text-white"><i class="fas fa-table me-2"></i> تفاصيل المبيعات الشهرية</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-dark table-hover mb-0 text-center">
                <thead>
                    <tr class="text-secondary">
                        <th>الشهر / السنة</th>
                        <th>إجمالي المبيعات</th>
                        <th>عدد الفواتير</th>
                        <th>متوسط الفاتورة</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in ViewBag.MonthlySalesData)
                    {
                        var monthName = new DateTime(item.Year, item.Month, 1).ToString("MMMM yyyy", new System.Globalization.CultureInfo("ar-EG"));
                        <tr>
                            <td class="text-info">@monthName</td>
                            <td class="fw-bold">@item.Total.ToString("N2") ج.م</td>
                            <td><span class="badge bg-secondary">@item.Count</span></td>
                            <td class="text-white small">@((item.Total / item.Count).ToString("N2"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>