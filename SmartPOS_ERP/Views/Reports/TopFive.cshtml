@{
    ViewData["Title"] = "تقارير المبيعات";
}

<div class="container-fluid bg-dark text-white p-4" style="min-height: 90vh;">
    <h3 class="text-info fw-bold mb-4"><i class="fas fa-chart-line me-2"></i> لوحة البيانات المالية</h3>

    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="card bg-secondary bg-opacity-10 border-info h-100 shadow-sm">
                <div class="card-body text-center p-4">
                    <h5 class="text-white-50 small uppercase">مبيعات اليوم</h5>
                    <h2 class="display-6 fw-bold text-info">@ViewBag.DailyTotal.ToString("N2") ج.م</h2>
                    <p class="mb-0 text-white small">عدد العمليات: @ViewBag.DailyCount</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card bg-secondary bg-opacity-10 border-warning h-100 shadow-sm">
                <div class="card-body text-center p-4">
                    <h5 class="text-white-50 small">مبيعات الشهر</h5>
                    <h2 class="display-6 fw-bold text-warning">@ViewBag.MonthlyTotal.ToString("N2") ج.م</h2>
                    <p class="mb-0 text-white small">عدد العمليات: @ViewBag.MonthlyCount</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card bg-secondary bg-opacity-10 border-secondary shadow">
                <div class="card-header border-secondary bg-transparent py-3">
                    <h5 class="text-info mb-0"><i class="fas fa-crown me-2"></i> أكثر 5 منتجات طلباً</h5>
                </div>
                <div class="card-body">
                    @foreach (var p in ViewBag.TopProducts)
                    {
                        <div class="mb-4">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-white">@p.ProductName</span>
                                <span class="text-warning">@p.TotalQty.ToString("N2") @(p.Unit == "Kilo" ? "كجم" : "قطعة")</span>
                            </div>
                            <div class="progress bg-dark border border-secondary" style="height: 12px;">
                                <div class="progress-bar bg-info shadow-sm" role="progressbar"
                                     style="width: @( (p.TotalQty > 100) ? 100 : p.TotalQty )%"></div>
                            </div>
                            <div class="text-end small text-white mt-1">إجمالي الدخل: @p.TotalSales.ToString("N2") ج.م</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>