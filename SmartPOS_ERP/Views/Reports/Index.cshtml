<div class="container-fluid bg-dark text-white p-4">
    <div class="row mb-4 align-items-end">
        <div class="col-md-4">
            <form asp-action="Index" method="get" class="card bg-secondary bg-opacity-10 border-info p-3">
                <label class="form-label text-info small">عرض مبيعات يوم محدد:</label>
                <div class="input-group">
                    <input type="date" name="selectedDate" value="@ViewBag.SelectedDate" class="form-control bg-dark text-white border-secondary">
                    <button type="submit" class="btn btn-info">بحث</button>
                </div>
            </form>
        </div>

        <div class="col-md-6">
            <form asp-action="Index" method="get" class="card bg-secondary bg-opacity-10 border-warning p-3">
                <label class="form-label text-warning small">عرض مبيعات شهر وسنة:</label>
                <div class="input-group">
                    <select name="selectedMonth" class="form-select bg-dark text-white border-secondary">
                        @for (int i = 1; i <= 12; i++)
                        {
                            <option value="@i" selected="@(i == ViewBag.SelectedMonth)">@i</option>
                        }
                    </select>
                    <input type="number" name="selectedYear" value="@ViewBag.SelectedYear" class="form-control bg-dark text-white border-secondary">
                    <button type="submit" class="btn btn-warning">عرض الشهر</button>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card bg-dark border-info p-4 text-center">
                <h6 class="text-info">إجمالي مبيعات تاريخ (@ViewBag.SelectedDate)</h6>
                <h2 class="text-white">@ViewBag.DailyTotal.ToString("N2") ج.م</h2>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card bg-dark border-warning p-4 text-center">
                <h6 class="text-warning">إجمالي مبيعات شهر (@ViewBag.SelectedMonth / @ViewBag.SelectedYear)</h6>
                <h2 class="text-white">@ViewBag.MonthlyTotal.ToString("N2") ج.م</h2>
            </div>
        </div>
    </div>
</div>